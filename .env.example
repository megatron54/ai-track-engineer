# ---------------------------------------------------------------------------
# AI-TrackEngineer — example environment configuration
# Copy this file to `.env` and adjust values. NEVER commit your real `.env`.
# ---------------------------------------------------------------------------

# --- Assetto Corsa ---------------------------------------------------------
# Optional. Leave blank to auto-detect the default Steam installation.
# Example (Steam default): C:\Program Files (x86)\Steam\steamapps\common\assettocorsa
AC_INSTALL_PATH=

# --- Application -----------------------------------------------------------
LOG_LEVEL=INFO
# Telemetry sample rate sent to the dashboard over WebSocket (Hz).
DASHBOARD_STREAM_HZ=30

# --- InfluxDB (time-series storage) ----------------------------------------
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=ai-track-engineer
INFLUXDB_BUCKET=telemetry
# Generate your own token; do not reuse this placeholder.
INFLUXDB_TOKEN=changeme-local-dev-token

# --- Ollama (local LLM) ----------------------------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
